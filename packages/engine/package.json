{
  "name": "@x/engine",
  "version": "0.1.0",
  "private": true,
  "description": "Optional headless/CI runner for non-interactive autonomous SDLC runs (LangGraph.js). Not used by the aix plugin path — there the host agent is the runtime.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "test": "node --test \"test/*.test.mjs\""
  },
  "dependencies": {
    "@langchain/langgraph": "^1.4.7",
    "@x/context": "workspace:*",
    "@x/core": "workspace:*",
    "@x/evals": "workspace:*",
    "@x/hitl": "workspace:*",
    "@x/memory": "workspace:*",
    "@x/policy": "workspace:*",
    "@x/prompt": "workspace:*",
    "@x/providers": "workspace:*",
    "@x/registry": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
