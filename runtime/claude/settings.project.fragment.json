{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .ai-harness/hooks/core/guard-phase.js --command harness-run --session .harness/sessions/<active-session> --json"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .ai-harness/hooks/core/guard-file-edits.js --json"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .ai-harness/hooks/core/record-tool-output.js --session .harness/sessions/<active-session> --command \"$COMMAND\" --exit-code \"$EXIT_CODE\" --summary \"Recorded by Claude hook adapter\" --used-by harness-verify"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .ai-harness/hooks/core/record-subagent-result.js --session .harness/sessions/<active-session> --agent \"$AGENT\" --status completed --summary \"Subagent completed\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .ai-harness/hooks/core/compact-session-memory.js --session .harness/sessions/<active-session>"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "ai-engineering-harness": {
      "source": {
        "source": "github",
        "repo": "truongnat/ai-engineering-harness"
      }
    }
  }
}
