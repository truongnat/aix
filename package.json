{
  "name": "ai-engineering-harness",
  "version": "1.0.1",
  "private": false,
  "description": "Engineering discipline and workflow guardrails for AI coding agents (Claude, Cursor, Codex, Gemini).",
  "keywords": [
    "ai",
    "agent",
    "claude",
    "cursor",
    "codex",
    "gemini",
    "workflow",
    "engineering",
    "guardrails",
    "markdown",
    "coding-agent",
    "discipline",
    "agentic-sdlc"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/truongnat/ai-engineering-harness"
  },
  "homepage": "https://ai-engineering-harness.dev",
  "bugs": {
    "url": "https://github.com/truongnat/ai-engineering-harness/issues"
  },
  "license": "MIT",
  "type": "commonjs",
  "types": "./index.d.ts",
  "bin": {
    "ai-engineering-harness": "./bin/aih.js",
    "aih": "./bin/aih.js"
  },
  "files": [
    "bin/",
    "lib/",
    "runtime/",
    "agent-system/",
    "commands/",
    "skills/",
    "workflows/",
    "patterns/",
    "templates/",
    "workers/",
    "rules/",
    "hooks/",
    "tool-capabilities/",
    "docs/",
    ".cursor-plugin/",
    ".claude-plugin/",
    ".codex-plugin/",
    "gemini-extension.json",
    "aih.sh",
    "aih.sh.sha256",
    "install.sh",
    "install-secure.sh",
    "aih.ps1",
    "install-cache.js",
    "install-runtime.js",
    "scripts/discover-tools.js",
    "scripts/generate-report-context.js",
    "runtime-command-catalog.js",
    "install.js",
    "validate.js",
    "index.d.ts",
    "AGENTS.md",
    "PACK.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "TARGET.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "scripts": {
    "install:harness": "node install.js",
    "test": "node --test test/run-tests.js test/cli-tests.js",
    "validate": "node validate.js",
    "lint": "eslint lib/ bin/ test/ --max-warnings 0",
    "lint:fix": "eslint lib/ bin/ test/ --fix",
    "format": "prettier --write lib/ bin/ test/ *.js *.md",
    "format:check": "prettier --check lib/ bin/ test/ *.js *.md"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "prettier": "^3.0.0"
  }
}
