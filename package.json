{
  "name": "ai-engineering-harness",
  "version": "1.0.1",
  "private": false,
  "description": "Engineering discipline and workflow guardrails for AI coding agents (Claude, Cursor, Codex, Gemini).",
  "keywords": [
    "ai",
    "agent",
    "claude",
    "cursor",
    "codex",
    "gemini",
    "workflow",
    "engineering",
    "guardrails",
    "markdown",
    "coding-agent",
    "discipline",
    "agentic-sdlc"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/truongnat/ai-engineering-harness"
  },
  "homepage": "https://ai-engineering-harness.dev",
  "bugs": {
    "url": "https://github.com/truongnat/ai-engineering-harness/issues"
  },
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "types": "./index.d.ts",
  "bin": {
    "ai-engineering-harness": "./bin/aih.js",
    "aih": "./bin/aih.js"
  },
  "files": [
    "bin/",
    "dist/",
    "evals/",
    "providers/",
    "runtime/",
    "agent-system/",
    "commands/",
    "skills/",
    "workflows/",
    "patterns/",
    "templates/",
    "workers/",
    "rules/",
    "hooks/",
    "tool-capabilities/",
    "docs/",
    "!docs/internal/",
    "!docs/pack-dogfood-reports/",
    "!docs/pack-dogfood-*.md",
    "!docs/*-plan.md",
    "!docs/*-readiness.md",
    "!docs/*-scope.md",
    "!docs/v0*.md",
    "!docs/enforcement-system-report-*.md",
    "!docs/gap-analysis.md",
    "!docs/frozen-*.md",
    "!docs/stable-contract-index.md",
    "!docs/system-positioning.md",
    ".cursor-plugin/",
    ".claude-plugin/",
    ".codex-plugin/",
    "gemini-extension.json",
    "aih.sh",
    "aih.sh.sha256",
    "install.sh",
    "install-secure.sh",
    "aih.ps1",
    "scripts/discover-tools.js",
    "scripts/generate-report-context.js",
    "scripts/generate-compatibility-matrix.js",
    "scripts/sync-site-version.js",
    "index.d.ts",
    "AGENTS.md",
    "PACK.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "TARGET.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "scripts": {
    "install:harness": "node bin/aih.js install",
    "build:preview-css": "tailwindcss -i v2/src/core/tools/preview/styles.css -o v2/src/core/tools/preview/assets/tailwind.css --minify",
    "build:preview-mermaid": "cp node_modules/mermaid/dist/mermaid.min.js v2/src/core/tools/preview/assets/mermaid.js",
    "build:preview-icons": "cp node_modules/lucide/dist/umd/lucide.min.js v2/src/core/tools/preview/assets/lucide.js",
    "build:preview": "npm run build:preview-css && npm run build:preview-mermaid && npm run build:preview-icons",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "npm run build && node --test",
    "test:evals": "npm run build && node --test test/evals/",
    "test:coverage": "npm run build && c8 --include=dist/lib/** --check-coverage --lines 65 --functions 65 --branches 55 --statements 65 node --test",
    "telemetry:server": "node bin/telemetry-server.js",
    "version-packages": "changeset version",
    "release": "npm publish",
    "prepare": "husky",
    "validate": "node bin/validate.js",
    "typecheck": "tsc -p tsconfig.lib.json",
    "lint": "eslint bin/ test/ *.js --max-warnings 0",
    "lint:fix": "eslint bin/ test/ *.js --fix",
    "format": "prettier --write lib/ bin/ test/ *.js *.md",
    "format:check": "prettier --check lib/ bin/ test/ *.js *.md",
    "generate:policy-docs": "node scripts/generate-policy-docs.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "cli-progress": "^3.12.0",
    "listr2": "^10.2.1",
    "lucide": "^1.21.0",
    "mermaid": "^11.15.0",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.6.0",
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "^25.9.4",
    "c8": "^10.1.3",
    "eslint": "^8.50.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
