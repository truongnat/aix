node_modules/
dist/

# TypeScript compiled output (now in dist/; lib/ is .ts source only)
dist/**/*.js
dist/**/*.js.map
dist/**/*.d.ts

# Local dogfood target repos (create beside pack; never commit)
harness-dogfood-*/
.env
.env.*
.DS_Store
*.log

# Always track required repository contracts even if a global gitignore ignores them
!AGENTS.md
!rules/providers/claude/CLAUDE.md
!agent-system/provider-adapters/claude.md

# Local harness runtime data
.harness/goals/
.harness/memory/local.md
.harness/*.local.md
events.jsonl

# Local eval run artifacts
artifacts/

# Coverage output
coverage/
.nyc_output/

# Large binary media (not shipped in this repo)
*.mp4
