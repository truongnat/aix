{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .ai-harness/hooks/core/run-with-active-session.js guard-phase --command harness-run --json"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .ai-harness/hooks/core/guard-file-edits.js --json"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .ai-harness/hooks/core/run-with-active-session.js record-tool-output --command \"$COMMAND\" --exit-code \"$EXIT_CODE\" --summary \"Recorded by Claude hook adapter\" --used-by harness-verify"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .ai-harness/hooks/core/run-with-active-session.js record-subagent-result --agent \"$AGENT\" --status completed --summary \"Subagent completed\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .ai-harness/hooks/core/run-with-active-session.js compact-session-memory"
          }
        ]
      }
    ]
  }
}
