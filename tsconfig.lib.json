{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "lib/cli-args.ts",
    "lib/cli-backend.ts",
    "lib/cli-command-helpers.ts",
    "lib/cli-commands/*.ts",
    "lib/cli-main.ts",
    "lib/cli-prompts.ts",
    "lib/cli-ui.ts",
    "lib/stack-detect.ts",
    "lib/domain-skill-generation.ts",
    "lib/report-template-discovery.ts",
    "lib/provider-interaction-tools.ts",
    "lib/evals/*.ts",
    "lib/insights/*.ts",
    "lib/validate/*.ts",
    "lib/catalog/provider-command-metadata.ts",
    "lib/catalog/command-rendering.ts",
    "lib/catalog/command-installation.ts",
    "lib/cli-detect.ts",
    "lib/provider-detection.ts",
    "lib/cli-help.ts",
    "lib/cli-plan.ts",
    "lib/cli-providers.ts",
    "lib/provider-registry.ts",
    "lib/provider-rule-renderer.ts",
    "lib/install-runtime.ts",
    "lib/install-cache.ts",
    "lib/command-surface-report.ts",
    "lib/file-operations.ts",
    "lib/plugin-packaging.ts",
    "lib/runtime-command-catalog.ts",
    "lib/worker-claude-adapter.ts",
    "lib/policy/*.ts",
    "lib/backend/*.ts",
    "workers/registry.ts"
  ]
}
