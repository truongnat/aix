<section class="section reveal" id="quickstart" aria-labelledby="quickstart-title">
  <div class="section-head">
    <p class="eyebrow">Launch sequence</p>
    <h2 id="quickstart-title">Boot a lifecycle-grade AI agent runtime locally</h2>
  </div>

  <div class="code-shell">
    <button class="copy-btn" type="button" data-copy-target="#quickstart-code">Copy</button>
    <pre id="quickstart-code"><code>cargo run -- workflow setup
cargo run -- workflow doctor
cargo run -- workflow check
cargo run -- workflow quality-skills --strict
cargo run -- workflow normalize-imported-skills --dry-run
cargo run -- --workflow-id feature --task "implement guarded release pipeline"
cargo run -- workflow trace &lt;instance_id&gt; --timeline</code></pre>
  </div>
</section>

