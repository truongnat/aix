---
const values = [
  {
    title: 'Deterministic Engine',
    body: 'The same workflow and input produce the same step order, telemetry shape, and execution semantics.'
  },
  {
    title: 'Policy Guardrails',
    body: 'Trust tiers, command constraints, protected-branch policy, and fail-fast logic are enforced at runtime.'
  },
  {
    title: 'Quality-Enforced Reporting',
    body: 'Workflow outputs are blocked when sparse; report quality gates demand actionable summaries and risks.'
  },
  {
    title: 'Lifecycle Coverage',
    body: 'From bugfix to release to review, templates and role packs cover real software lifecycle operations.'
  },
  {
    title: 'Imported Skill Governance',
    body: 'Normalize imported skill metadata (`risk/source/tags`) and keep provenance lockfile-aligned.'
  },
  {
    title: 'Operator Visibility',
    body: 'Per-step status, duration, actions, risks, provider, and model metadata are visible in run summaries.'
  }
];
---

<section class="section reveal" id="platform" aria-labelledby="platform-title">
  <div class="section-head">
    <p class="eyebrow">Platform</p>
    <h2 id="platform-title">Built for teams running AI agents in production SDLC loops</h2>
  </div>

  <div class="capability-grid">
    {
      values.map((item) => (
        <article class="capability-card">
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))
    }
  </div>
</section>
