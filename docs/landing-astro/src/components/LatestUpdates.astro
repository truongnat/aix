<section class="section reveal" id="ops-console" aria-labelledby="ops-console-title">
  <div class="section-head">
    <p class="eyebrow">Ops Console</p>
    <h2 id="ops-console-title">Operate agents like an engineering system, not a chat transcript</h2>
  </div>

  <div class="console-grid">
    <article class="console-card">
      <h3>Release Gate Deck</h3>
      <ul class="check-list">
        <li>Package structure check passed</li>
        <li>Role/rule/skill quality conventions validated</li>
        <li>Report-quality gate accepted actionable output</li>
        <li>Protected branch policy verified before merge</li>
      </ul>
    </article>

    <article class="console-card">
      <h3>Role + Skill Matrix</h3>
      <div class="tag-cloud">
        <span>architect</span>
        <span>implementer</span>
        <span>reviewer</span>
        <span>releaser</span>
        <span>resolver</span>
        <span>workflow_report</span>
        <span>report_quality_gate</span>
        <span>risk_register</span>
        <span>security_scan_guard</span>
      </div>
    </article>

    <article class="console-card code-card">
      <h3>Thread Run Telemetry</h3>
      <pre><code>Implementation run: status=completed trace=trc_2f19...
- [completed] intent_analysis duration_ms=964 actions=4 risks=2
- [completed] workflow_report duration_ms=801 actions=6 risks=3
- [completed] report_quality_gate duration_ms=118 actions=0 risks=0
Merge run: status=completed steps=7/7 failed=0</code></pre>
    </article>

    <article class="console-card">
      <h3>Normalization Control</h3>
      <p>
        Keep imported skill packs consistent with lockfile provenance before production use.
      </p>
      <pre><code>cargo run -- workflow normalize-imported-skills --dry-run
cargo run -- workflow normalize-imported-skills --json</code></pre>
    </article>
  </div>
</section>
