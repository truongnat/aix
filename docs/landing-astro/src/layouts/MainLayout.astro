---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'agentic-sdlc | Deterministic Runtime for Agentic SDLC',
  description = 'A deterministic local runtime to run AI-agent workflows with policy safety, resumable state, and audit-grade traces.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="ambient" aria-hidden="true"></div>
    <slot />
  </body>
</html>
