# kb-server configuration — copy to .env and fill in. Do NOT commit .env.

# Admin master password (required; server refuses to start without it).
KB_MASTER_PASSWORD=change-me-to-a-strong-secret

# HTTP port the NestJS app listens on (matches `aix doctor` check).
PORT=4000

# Neo4j (graph store)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Meilisearch (full-text search)
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=masterKey

# Redis (search/get cache)
REDIS_URL=redis://localhost:6379
